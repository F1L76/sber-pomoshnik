# Authorization key из https://developers.sber.ru/studio/ (вкладка «Настройки API»).
# Им пользуются для POST oauth; сам ключ не «горит через 30 минут». ~30 мин живёт access_token —
# локальный gigachat-proxy.mjs сам запрашивает новый токен по этому ключу.
GIGACHAT_CREDENTIALS=ваш_ключ_authorization_data

# GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель: GigaChat, GigaChat-Pro, GigaChat-Max и т.д.
GIGACHAT_MODEL=GigaChat

PORT=8787

# Опционально: API-ключ Яндекс Карт (https://developer.tech.yandex.ru/) для геокодера и JS API
# YANDEX_MAPS_API_KEY=ваш_ключ

# Опционально: API-ключ 2ГИС (https://dev.2gis.com/) — фото зданий в кадастровом поиске
# DGIS_API_KEY=ваш_ключ

# CSV со сделками/арендой (по умолчанию data/deals/, также ~/Downloads)
# DEALS_DATASET_PATH=/путь/к/одному/файлу.csv
# DEALS_DATASET_PATHS=/путь/1.csv;/путь/2.csv

# AI Gateway / Langflow — служебные записки (корпоративная сеть банка)
LANGFLOW_API_KEY=ваш_x_api_key
# При необходимости другой flow:
# LANGFLOW_RUN_URL=https://aigateway.delta.sbrf.ru/langflow/api/v1/run/ВАШ_FLOW_ID
